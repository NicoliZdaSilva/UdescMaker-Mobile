# Backend público
UDESCMAKER_API_PUBLIC_URL=http://localhost:8080
UDESCMAKER_SITE_URL=http://localhost:4321
UDESCMAKER_CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
UDESCMAKER_CORS_ALLOW_CREDENTIALS=false

# Catálogo: local | github (test é reservado aos testes automatizados)
UDESCMAKER_CATALOG_MODE=local
UDESCMAKER_CATALOG_LOCAL_PATH=../udescmaker/src/content/projects
UDESCMAKER_CATALOG_CACHE_TTL=PT5M

# Destino GitHub fixado pelo servidor; nunca exponha o token no Expo
UDESCMAKER_GITHUB_OWNER=SamuelGislon
UDESCMAKER_GITHUB_REPOSITORY=udescmaker
UDESCMAKER_GITHUB_BRANCH=main
UDESCMAKER_GITHUB_PROJECTS_PATH=src/content/projects
UDESCMAKER_GITHUB_API_URL=https://api.github.com
UDESCMAKER_GITHUB_RAW_URL=https://raw.githubusercontent.com
UDESCMAKER_GITHUB_TOKEN=
UDESCMAKER_GITHUB_PUBLISH_ENABLED=false

# Uploads
UDESCMAKER_MAX_FILE_SIZE=20MB
UDESCMAKER_MAX_REQUEST_SIZE=100MB
UDESCMAKER_UPLOAD_MAX_FILE_BYTES=20971520
UDESCMAKER_UPLOAD_MAX_TOTAL_BYTES=104857600

# Única variável pública do aplicativo mobile
EXPO_PUBLIC_API_URL=http://localhost:8080/api
